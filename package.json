{
  "name": "flashcards",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "deploy": "node scripts/deploy.mjs",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "build": "next build",
    "test": "vitest run",
    "check:format": "prettier --check .",
    "check:lint": "eslint .",
    "check:type": "tsc --noEmit",
    "check:openspec": "openspec validate --all --strict",
    "check": "npm run check:format && npm run check:lint && npm run check:type && npm run check:openspec && npm run test && npm run build && npm run db:check",
    "prepare": "husky"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.9",
    "postgres": "^3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,css,md}": "prettier --write --ignore-unknown",
    "*.{js,jsx,ts,tsx,mjs,cjs}": "eslint --fix"
  },
  "devDependencies": {
    "@fission-ai/openspec": "^1.6.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.7",
    "impeccable": "^3.2.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "supabase": "^2.109.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vercel": "^54.18.7",
    "vitest": "^4.1.10"
  }
}
